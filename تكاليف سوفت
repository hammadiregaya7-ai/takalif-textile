<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>تكاليف سوفت - النسيج (SQLite)</title>
  <script src="https://cdn.jsdelivr.net/npm/sql.js@1.14.0/dist/sql-wasm.js"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body { font-family: system-ui, sans-serif; }
    .teal { background-color: #0f766e; }
    .screen { display: none; }
    .active { display: block; }
  </style>
</head>
<body class="bg-gray-100 rtl">

  <!-- Top Bar -->
  <div class="teal text-white p-4 flex items-center justify-between sticky top-0 z-50">
    <div class="flex items-center gap-3">
      <i onclick="showScreen('dashboard')" class="fas fa-bars text-3xl cursor-pointer"></i>
      <h1 class="text-2xl font-bold">تكاليف سوفت - النسيج</h1>
    </div>
  </div>

  <!-- Navigation -->
  <div class="bg-white border-b flex text-center text-sm font-medium overflow-x-auto">
    <button onclick="showScreen('dashboard')" class="flex-1 py-4 px-2 border-b-2 border-transparent active:border-teal-600">الرئيسية</button>
    <button onclick="showScreen('sales')" class="flex-1 py-4 px-2 border-b-2 border-transparent active:border-teal-600">المبيعات</button>
    <button onclick="showScreen('products')" class="flex-1 py-4 px-2 border-b-2 border-transparent active:border-teal-600">الأصناف</button>
    <button onclick="showScreen('data')" class="flex-1 py-4 px-2 border-b-2 border-transparent active:border-teal-600 font-bold">إدارة البيانات</button>
  </div>

  <!-- DASHBOARD -->
  <div id="dashboard" class="screen active p-4">
    <div class="grid grid-cols-2 gap-4">
      <div class="bg-white rounded-3xl p-6 shadow text-center">
        <p class="text-gray-500">إجمالي المبيعات</p>
        <p id="total-sales" class="text-4xl font-bold text-teal-600">0 ريال</p>
      </div>
      <div class="bg-white rounded-3xl p-6 shadow text-center">
        <p class="text-gray-500">مخزون منخفض</p>
        <p id="low-stock" class="text-4xl font-bold text-orange-600">0</p>
      </div>
    </div>
  </div>

  <!-- SALES SCREEN -->
  <div id="sales" class="screen p-4">
    <h2 class="text-2xl font-bold mb-4">بيع آجل</h2>
    <div class="bg-white rounded-3xl p-6 shadow">
      <input id="customer-name" type="text" placeholder="اسم العميل" class="w-full p-4 border rounded-2xl mb-4" value="يوسف عمار">
      <select id="product-select" class="w-full p-4 border rounded-2xl mb-4"></select>
      <div class="grid grid-cols-3 gap-4">
        <div><label class="text-sm">متر</label><input id="qty-meters" type="number" value="10" class="w-full p-4 border rounded-2xl"></div>
        <div><label class="text-sm">اللون</label><input id="color-input" type="text" value="أزرق" class="w-full p-4 border rounded-2xl"></div>
        <div><label class="text-sm">رقم اللفة</label><input id="roll-number" type="text" value="LF-001" class="w-full p-4 border rounded-2xl"></div>
      </div>
      <button onclick="addItemToInvoice()" class="mt-6 w-full bg-teal-600 text-white py-5 rounded-3xl text-xl font-bold">إضافة إلى الفاتورة</button>
      <div id="current-invoice" class="mt-6 space-y-3"></div>
      <div class="flex justify-between text-2xl font-bold mt-8 pt-6 border-t">
        <span>الإجمالي</span>
        <span id="invoice-total">0 ريال</span>
      </div>
      <div class="grid grid-cols-2 gap-4 mt-8">
        <button onclick="saveCurrentInvoice()" class="bg-green-600 text-white py-6 rounded-3xl text-xl font-bold">حفظ الفاتورة</button>
        <button onclick="printCurrentInvoice()" class="bg-blue-600 text-white py-6 rounded-3xl text-xl font-bold">طباعة</button>
      </div>
    </div>
  </div>

  <!-- PRODUCTS -->
  <div id="products" class="screen p-4">
    <h2 class="text-2xl font-bold mb-4">الأصناف والمخزون</h2>
    <button onclick="addNewProduct()" class="w-full bg-teal-600 text-white py-4 rounded-3xl mb-6">+ إضافة صنف قماش جديد</button>
    <div id="products-list" class="space-y-4"></div>
  </div>

  <!-- DATA MANAGEMENT (SQLite) -->
  <div id="data" class="screen p-4">
    <h2 class="text-2xl font-bold mb-6">إدارة البيانات (SQLite)</h2>
    <div class="bg-white rounded-3xl p-6 shadow space-y-6">
      <button onclick="exportDB()" class="w-full bg-blue-600 text-white py-5 rounded-3xl">📤 تصدير قاعدة البيانات (.db)</button>
      <label class="w-full bg-purple-600 text-white py-5 rounded-3xl flex items-center justify-center cursor-pointer">
        📥 استيراد قاعدة بيانات
        <input type="file" id="importFile" accept=".db" class="hidden" onchange="importDB(event)">
      </label>
      <button onclick="runDemoQuery()" class="w-full bg-teal-600 text-white py-5 rounded-3xl">🔍 تشغيل استعلام اختباري</button>
      <button onclick="clearDB()" class="w-full bg-red-600 text-white py-5 rounded-3xl">🗑️ مسح قاعدة البيانات</button>
    </div>
    <div id="sql-result" class="mt-8 bg-white rounded-3xl p-6 text-xs overflow-auto max-h-96 hidden"></div>
  </div>

  <script>
    let db;
    let currentInvoice = [];

    async function initSQLite() {
      const config = {
        locateFile: file => `https://cdn.jsdelivr.net/npm/sql.js@1.14.0/dist/${file}`
      };
      const SQL = await initSqlJs(config);
      db = new SQL.Database();

      // Create tables (textile-specific)
      db.run(`
        CREATE TABLE IF NOT EXISTS products (
          id INTEGER PRIMARY KEY,
          name TEXT,
          price REAL,
          stock REAL DEFAULT 0,
          color TEXT,
          unit TEXT DEFAULT 'متر'
        );
        CREATE TABLE IF NOT EXISTS invoices (
          id INTEGER PRIMARY KEY,
          date TEXT,
          customer TEXT,
          total REAL
        );
        CREATE TABLE IF NOT EXISTS invoice_items (
          id INTEGER PRIMARY KEY,
          invoice_id INTEGER,
          product_id INTEGER,
          meters REAL,
          color TEXT,
          roll TEXT,
          subtotal REAL
        );
      `);

      // Add sample data if empty
      const res = db.exec("SELECT COUNT(*) as count FROM products");
      if (res[0].values[0][0] === 0) {
        db.run(`INSERT INTO products (name, price, stock, color) VALUES 
          ('قماش قطني', 120, 450, 'متعدد'),
          ('قماش بوليستر', 85, 320, 'متعدد'),
          ('قماش حرير', 250, 80, 'متعدد');`);
      }
      console.log('%c✅ SQLite جاهزة!', 'color:#0f766e; font-size:18px');
      refreshAll();
    }

    function refreshAll() {
      renderProducts();
      renderDashboard();
      populateProductSelect();
    }

    function showScreen(id) {
      document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
      document.getElementById(id).classList.add('active');
      if (id === 'products') renderProducts();
      if (id === 'dashboard') renderDashboard();
    }

    function renderProducts() {
      const stmt = db.prepare("SELECT * FROM products");
      let html = '';
      while (stmt.step()) {
        const p = stmt.getAsObject();
        html += `
          <div class="bg-white p-5 rounded-3xl shadow flex justify-between">
            <div>
              <div class="font-bold">${p.name}</div>
              <div class="text-sm text-gray-500">${p.color} • ${p.stock} متر</div>
            </div>
            <div class="text-right font-bold">${p.price} ريال/متر</div>
          </div>`;
      }
      document.getElementById('products-list').innerHTML = html || '<p class="text-gray-500">لا توجد أصناف</p>';
      stmt.free();
    }

    function addNewProduct() {
      const name = prompt("اسم الصنف:");
      if (!name) return;
      const price = parseFloat(prompt("السعر للمتر:", "120"));
      const stock = parseFloat(prompt("المخزون (متر):", "100"));
      const color = prompt("اللون:", "متعدد");
      db.run("INSERT INTO products (name, price, stock, color) VALUES (?, ?, ?, ?)", [name, price, stock, color]);
      refreshAll();
    }

    function populateProductSelect() {
      const select = document.getElementById('product-select');
      select.innerHTML = '';
      const stmt = db.prepare("SELECT id, name, price, stock FROM products");
      while (stmt.step()) {
        const p = stmt.getAsObject();
        const opt = document.createElement('option');
        opt.value = p.id;
        opt.textContent = `${p.name} - ${p.price} ريال (مخزون: ${p.stock})`;
        select.appendChild(opt);
      }
      stmt.free();
    }

    function addItemToInvoice() {
      const productId = parseInt(document.getElementById('product-select').value);
      const meters = parseFloat(document.getElementById('qty-meters').value);
      const color = document.getElementById('color-input').value;
      const roll = document.getElementById('roll-number').value;

      const stmt = db.prepare("SELECT price, stock FROM products WHERE id = ?");
      stmt.bind([productId]);
      if (stmt.step()) {
        const product = stmt.getAsObject();
        if (meters > product.stock) return alert("⚠️ الكمية أكبر من المخزون!");
        const subtotal = meters * product.price;
        currentInvoice.push({productId, meters, color, roll, price: product.price, subtotal});
        renderCurrentInvoice();
      }
      stmt.free();
    }

    function renderCurrentInvoice() {
      const container = document.getElementById('current-invoice');
      container.innerHTML = currentInvoice.map((item, i) => `
        <div class="flex justify-between bg-gray-50 p-4 rounded-2xl">
          <div><strong>${item.meters}م</strong> ${item.color} لفة ${item.roll}</div>
          <div class="text-right font-bold">${item.subtotal.toFixed(0)} ريال</div>
        </div>`).join('');
      const total = currentInvoice.reduce((sum, i) => sum + i.subtotal, 0);
      document.getElementById('invoice-total').textContent = total.toFixed(0) + ' ريال';
    }

    function saveCurrentInvoice() {
      if (currentInvoice.length === 0) return alert("أضف أصناف أولاً");
      const customer = document.getElementById('customer-name').value || "عميل عام";
      const total = currentInvoice.reduce((sum, i) => sum + i.subtotal, 0);
      const date = new Date().toLocaleDateString('ar');

      db.run("INSERT INTO invoices (date, customer, total) VALUES (?, ?, ?)", [date, customer, total]);
      const invoiceId = db.exec("SELECT last_insert_rowid()")[0].values[0][0];

      currentInvoice.forEach(item => {
        db.run("INSERT INTO invoice_items (invoice_id, product_id, meters, color, roll, subtotal) VALUES (?, ?, ?, ?, ?, ?)",
          [invoiceId, item.productId, item.meters, item.color, item.roll, item.subtotal]);
      });

      // Update stock
      currentInvoice.forEach(item => {
        db.run("UPDATE products SET stock = stock - ? WHERE id = ?", [item.meters, item.productId]);
      });

      alert(`✅ تم حفظ الفاتورة بنجاح!`);
      currentInvoice = [];
      renderCurrentInvoice();
      refreshAll();
    }

    function printCurrentInvoice() {
      // Same as before - works with current invoice
      alert("🖨️ سيتم تطوير الطباعة الكاملة في الخطوة القادمة");
    }

    function renderDashboard() {
      const res = db.exec("SELECT COALESCE(SUM(total),0) as total FROM invoices");
      document.getElementById('total-sales').textContent = (res[0]?.values[0][0] || 0) + ' ريال';
      const low = db.exec("SELECT COUNT(*) FROM products WHERE stock < 50");
      document.getElementById('low-stock').textContent = low[0].values[0][0];
    }

    // SQLite Data Tools
    function exportDB() {
      const data = db.export();
      const blob = new Blob([data], { type: 'application/octet-stream' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `takalif_textile_${new Date().toISOString().slice(0,10)}.db`;
      a.click();
      URL.revokeObjectURL(url);
    }

    function importDB(e) {
      const file = e.target.files[0];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = function(ev) {
        try {
          const uint8 = new Uint8Array(ev.target.result);
          db = new SQL.Database(uint8);
          alert('✅ تم استيراد قاعدة البيانات بنجاح!');
          refreshAll();
        } catch(err) {
          alert('خطأ في الملف');
        }
      };
      reader.readAsArrayBuffer(file);
    }

    function runDemoQuery() {
      const result = db.exec("SELECT * FROM products LIMIT 5");
      let html = '<pre>' + JSON.stringify(result, null, 2) + '</pre>';
      document.getElementById('sql-result').innerHTML = html;
      document.getElementById('sql-result').classList.remove('hidden');
    }

    function clearDB() {
      if (confirm('⚠️ مسح كل البيانات؟')) {
        db = new SQL.Database();
        initSQLite(); // recreate tables
      }
    }

    // Start the app
    window.onload = initSQLite;
  </script>
</body>
</html>